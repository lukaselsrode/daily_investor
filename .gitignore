# Python
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Secrets & credentials
.env
.env.*
*.credentials.*
credentials.*
*.key
*.pem

# Logs & runtime data
*.log
# Root-level runtime artifacts dir (CSVs, snapshots). Anchored to repo root with
# a leading slash so it does NOT also match src/data/ — which is Python SOURCE
# (data.sentiment, data.market_structure, data.fundamentals, ...) that tracked
# modules import via `from data.x import`. An unanchored `data/` silently
# excluded those source files from version control.
/data/

# Ephemeral config artifacts (must never re-accumulate as tracked files)
#   - cfg/*.bak*: migrate-scoring backups + timestamped config backups written
#     next to the source config (e.g. config.yaml.bak, config.yaml.bak-<ts>)
#   - .variants/: user-saved UI config variants (DAILY_INVESTOR_VARIANTS_DIR)
#   - *.bak.parquet: in-place snapshot rescore backups
cfg/*.bak*
.variants/
*.bak.parquet

# Claude / editor
.claude/

# Understand-anything knowledge graph (regenerable tooling artifact; auto-updates)
.understand-anything/

# macOS
.DS_Store
.session_tmp/
